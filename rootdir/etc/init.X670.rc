# Infinix X670 specific init rc

on init
    # Set ro.product.mod_device
    setprop ro.product.mod_device X670_GL

    # Set touchscreen permissions
    chmod 0666 /dev/touchpanel
    chown system system /dev/touchpanel

    # Set sensor permissions
    chmod 0666 /dev/hwmsensor
    chown system system /dev/hwmsensor

on boot
    # Enable ZRAM
    swapon_all /vendor/etc/fstab.enableswap

    # Set CPU governor
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu1/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu2/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu3/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu5/cpufreq/scaling_governor schedutil

    # Enable scheduler boost
    write /proc/sys/kernel/sched_boost 1
